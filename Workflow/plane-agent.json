        "url": "=http://host.docker.internal:8000/api/v1/workspaces/office/projects/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "X-API-Key", "value": "plane_api_2f8f19fa934b4f72a65518f7422aadc6"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "options": {"timeout": 15000}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1680, 200],
      "id": "plane-agent-list-projects-0007",
      "name": "Plane API: list projects",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nif (!data || data.error) {\n  return [{ json: { response: 'error', error: 'Plane API: ' + (data && data.error ? data.error : 'нет ответа') } }];\n}\n// list_projects вернёт пагинированный объект — извлекаем results\nconst projects = (data.results || []).map(p => ({\n  id: p.id,\n  name: p.name,\n  identifier: p.identifier,\n  total_members: p.total_members,\n  is_member: p.is_member\n}));\nreturn [{ json: { response: 'ok', projects, count: projects.length } }];"
      },
