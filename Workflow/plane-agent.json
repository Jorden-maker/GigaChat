      "webhookId": "plane-agent-webhook-001"
    },
    {
      "parameters": {
        "jsCode": "// Валидация запроса от GigaChat фронта.\n// action — что делать (list_projects, list_issues, create_issue, ...)\n// token — наш GigaChat-token (от planner_sessions), не Plane API token.\nconst body = $input.first().json.body || {};\nconst action = String(body.action || 'list_projects').trim();\nconst ALLOWED = ['ping', 'list_projects', 'list_issues', 'create_issue', 'update_issue', 'delete_issue', 'search_issues'];\nif (!ALLOWED.includes(action)) {\n  return [{ json: { valid: 0, error: 'Неизвестный action: ' + action } }];\n}\nif (action === 'ping') {\n  return [{ json: { valid: 0, error: 'pong', action: 'ping' } }];\n}\nconst token = String(body.token || '').trim();\nif (!/^[a-f0-9]{64}$/.test(token)) {\n  return [{ json: { valid: 0, error: 'unauthorized', auth_required: true } }];\n}\nreturn [{ json: { valid: 1, action, token, body } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [280, 300],
      "id": "plane-agent-validate-0002",
      "name": "Валидация"
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "loose"},
          "conditions": [{
            "id": "cond-valid",
            "leftValue": "={{ $json.valid }}",
            "rightValue": 1,
            "operator": {"type": "number", "operation": "equals"}
          }],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [560, 300],
      "id": "plane-agent-if-valid-0003",
      "name": "Валидно?"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE planner_sessions SET last_used_at = NOW() WHERE token = $1 AND expires_at > NOW();\nSELECT s.user_id, u.username FROM planner_sessions s JOIN planner_users u ON u.id = s.user_id WHERE s.token = $1 AND s.expires_at > NOW();",
        "options": {"queryReplacement": "={{ [$json.token] }}"},
        "alwaysOutputData": true
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [840, 300],
      "id": "plane-agent-verify-sql-0004",
      "name": "SQL: Verify token",
      "credentials": {
        "postgres": {"id": "OYsyciMf7Eq9W4FS", "name": "Postgres"}
      },
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst data = item && item.json ? item.json : null;\nconst src = $('Валидация').first().json;\nif (!data || !data.user_id) {\n  return [{ json: { token_valid: false, response: 'error', error: 'unauthorized', auth_required: true } }];\n}\nreturn [{ json: { ...src, token_valid: true, user_id: data.user_id, username: data.username } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300],
      "id": "plane-agent-token-result-0005",
      "name": "Token result"
    },
