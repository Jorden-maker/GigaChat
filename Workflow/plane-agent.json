            "rightValue": true,
            "operator": {"type": "boolean", "operation": "true"}
          }],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1400, 300],
      "id": "plane-agent-if-token-0006",
      "name": "Token OK?"
    },
